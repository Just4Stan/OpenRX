(footprint "OpenRX-Shared:SolderPad_1.0x0.8mm"
	(version 20240108)
	(generator "hand")
	(layer "F.Cu")
	(descr "Compact solder pad 1.0x0.8mm for wire connection")
	(tags "solder pad test point connector")
	(attr smd)
	(fp_text reference "REF**" (at 0 -1.2) (layer "F.SilkS")
		(effects (font (size 0.6 0.6) (thickness 0.1)))
	)
	(fp_text value "Pad" (at 0 1.2) (layer "F.Fab")
		(effects (font (size 0.6 0.6) (thickness 0.1)))
	)
	(pad "1" smd rect
		(at 0 0)
		(size 1.0 0.8)
		(layers "F.Cu" "F.Paste" "F.Mask")
	)
	(fp_line (start -0.7 -0.6) (end 0.7 -0.6) (layer "F.CrtYd") (stroke (width 0.05) (type solid)))
	(fp_line (start 0.7 -0.6) (end 0.7 0.6) (layer "F.CrtYd") (stroke (width 0.05) (type solid)))
	(fp_line (start 0.7 0.6) (end -0.7 0.6) (layer "F.CrtYd") (stroke (width 0.05) (type solid)))
	(fp_line (start -0.7 0.6) (end -0.7 -0.6) (layer "F.CrtYd") (stroke (width 0.05) (type solid)))
	(model "${KIPRJMOD}/../shared/libs/OpenRX-Shared.3dshapes/SolderPad_1.0x0.8mm.wrl"
		(offset
			(xyz 0 0 0)
		)
		(scale
			(xyz 1 1 1)
		)
		(rotate
			(xyz 0 0 0)
		)
	)
)
