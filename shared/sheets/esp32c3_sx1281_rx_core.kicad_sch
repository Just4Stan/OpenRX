	)
	(text "SX1281 pin contract already validated against local ExpressLRS:\nuse logical radio_dio1 for IRQ, not radio_dio0.\nKeep BUSY and RST in the baseline."
		(exclude_from_sim no)
		(at 199.39 71.12 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "a0878990-2410-4ebf-b4f4-21a411629df0")
	)
	(text "This sheet is the reusable capture host for the Lite/Nano SX1281 family."
		(exclude_from_sim no)
		(at 19.05 22.86 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "a115f163-2d94-4be9-a781-fcccd24bf882")
	)
	(text "U3  TLV75533PDQNR\nC1  1uF local VIN cap\nC2  1uF local VOUT cap\n10uF bulk at 5V entry\n10uF bulk on +3.3V rail\nVIN 5V input rail\nVOUT +3.3V system rail"
		(exclude_from_sim no)
		(at 24.13 54.61 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "bd72c569-72d2-4d1c-9e4d-4642a9f175f5")
	)
	(text "U1  ESP32-C3FH4\nY1  40MHz crystal\nR1/C6 EN RC delay\nR2 NSS pull-up\nR3 BOOT pull-up\nOptional GPIO9 boot pad\nOptional GPIO18/GPIO19 USB test pads"
		(exclude_from_sim no)
		(at 92.71 41.91 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "c34e3f3e-7345-444b-8910-e4fab609b16e")
	)
	(text "Firmware-critical mapping:\nGPIO4 = radio_sck\nGPIO5 = radio_dio1\nGPIO6 = radio_miso\nGPIO7 = radio_mosi\nGPIO8 = radio_nss\nGPIO3 = radio_busy\nGPIO2 = radio_rst\nU0RXD = serial_rx\nU0TXD = serial_tx"
		(exclude_from_sim no)
		(at 92.71 71.12 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "dce62a7f-2ffc-4539-9c16-b75d9d8ad97d")
	)
	(text "POWER"
		(exclude_from_sim no)
		(at 24.13 46.99 0)
		(effects
			(font
				(size 1.778 1.778)
			)
		)
		(uuid "e77f6d63-f288-47c9-b546-9b5e5d74627e")
	)
	(text "ANT1 2450AT18A100E\nL1/C16 Lite matching network\nNo PA/LNA in the shared Lite core\nKeep antenna edge-placement and keepout in PCB work"
		(exclude_from_sim no)
		(at 313.69 54.61 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "ed681b01-e5f7-4780-b193-70ed47931e29")
	)
	(text "U2  SX1281IMLTRT\nY2  52MHz TCXO\nC9/C10/C12/C13 supply decoupling\nR5/C11 radio reset network\nLDO mode on VR_PA\nDIO2/DIO3 left unused in Lite baseline"
		(exclude_from_sim no)
		(at 199.39 41.91 0)
